# Copy this file to .env and fill in your credentials
SECRET_KEY=cambia-esto-por-una-clave-segura

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-contrasena

# Gmail OAuth2 — Google Cloud Console → APIs & Services → Credentials
# Tipo: Web application | URI de redirección: https://datos.papiatech.com/emails/oauth2callback
GMAIL_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_REDIRECT_URI=https://datos.papiatech.com/emails/oauth2callback

# Twilio — WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Webhook público (para registrar en Twilio Sandbox)
# https://datos.papiatech.com/webhook/whatsapp
